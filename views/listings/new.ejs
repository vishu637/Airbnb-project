<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center py-5">
  <div class="col-12 col-md-8 col-lg-6">

    <div class="bg-body-tertiary border rounded-4 p-4 p-md-5">

      <h3 class="text-center fw-bold mb-1">Create New Listing</h3>
      <p class="text-center text-muted mb-4">
        Add details for your new property
      </p>

      <form method="POST" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">

        <!-- Title -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Title</label>
          <input
            type="text"
            class="form-control form-control-lg"
            name="listing[title]"
            placeholder="Beautiful apartment"
            required
          >
          <div class="invalid-feedback">Please enter a title</div>
        </div>

        <!-- Description -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Description</label>
          <textarea
            class="form-control"
            name="listing[description]"
            rows="3"
            placeholder="Describe your listing..."
            required
          ></textarea>
          <div class="invalid-feedback">Please enter a description</div>
        </div>

<!-- Category -->
<div class="mb-3">
  <label class="form-label fw-semibold">Category</label>
  
  <select class="form-control" name="listing[category]" required>
    <option value="">Select Category</option>
    <option value="Trending">Trending</option>
    <option value="Rooms">Rooms</option>
    <option value="Iconic Cities">Iconic Cities</option>
    <option value="Catles">Catles</option>
    <option value="Mountains">Mountains</option>
    <option value="Camping">Camping</option>
    <option value="Farms">Farms</option>
    <option value="Arctic">Arctic</option>
    <option value="Dome">Dome</option>
    <option value="HouseBoat">HouseBoat</option>
  </select>

  <div class="invalid-feedback">Please select a category</div>
</div>

        <!-- Location -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Location</label>
          <input
            type="text"
            class="form-control"
            name="listing[location]"
            placeholder="City, State"
            required
          >
          <div class="invalid-feedback">Please enter a valid location</div>
        </div>

        <!-- Latitude & Longitude -->
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Latitude</label>
            <input
              type="number"
              step="any"
              class="form-control"
              name="listing[latitude]"
              placeholder="18.5204"
            >
          </div>

          <div class="col-md-6">
            <label class="form-label fw-semibold">Longitude</label>
            <input
              type="number"
              step="any"
              class="form-control"
              name="listing[longitude]"
              placeholder="73.8567"
            >
          </div>
        </div>

        <!-- Price & Country -->
        <div class="row g-3 mt-1">
          <div class="col-md-4">
            <label class="form-label fw-semibold">Price</label>
            <div class="input-group">
              <span class="input-group-text">₹</span>
              <input
                type="number"
                class="form-control"
                name="listing[price]"
                placeholder="5000"
                required
              >
            </div>
            <div class="invalid-feedback">Enter a valid price</div>
          </div>

          <div class="col-md-8">
            <label class="form-label fw-semibold">Country</label>
            <input
              type="text"
              class="form-control"
              name="listing[country]"
              placeholder="India"
              required
            >
            <div class="invalid-feedback">Please enter a country</div>
          </div>
        </div>

        <!-- Image -->
        <div class="mt-3">
          <label class="form-label fw-semibold">Upload Image</label>
          <input
            type="file"
            class="form-control"
            name="listing[image]"
          >
        </div>

        <!-- Button -->
        <div class="d-grid mt-4">
          <button class="btn btn-dark btn-lg rounded-3">
            Add Listing
          </button>
        </div>

      </form>
    </div>

  </div>
</div>